{
  "manifest_version": 3,
  "name": "JobCruncher - Job Application Tracker",
  "version": "1.0",
  "description": "Track and manage job applications on LinkedIn & Indeed. Save jobs, export to CSV & Google Sheets, track application status.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/*",
        "https://indeed.com/*",
        "https://*.indeed.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
